<Page x:Class="unoappwritetrae20260119.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:unoappwritetrae20260119.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{StaticResource AppCanvasBrush}">

    <Page.Resources>
        <Style x:Key="HeaderLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="HeaderValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid" utu:SafeArea.Insets="VisibleBounds">
        <!--<tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="UnoAppwriteTrae"
                        IconSource="ms-appx:///icon.ico"
                        LeftClickCommand="{x:Bind RestoreCommand}" />-->

        <Grid>
            <Border Width="420"
                    Height="420"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="-140,-120,0,0"
                    Background="{StaticResource AccentSoftBrush}"
                    Opacity="0.72"
                    CornerRadius="210"/>
            <Border Width="360"
                    Height="360"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-100,-90,0"
                    Background="#DDE9F7"
                    Opacity="0.8"
                    CornerRadius="180"/>
            <Border Width="540"
                    Height="540"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,-280"
                    Background="#E8F0D5"
                    Opacity="0.45"
                    CornerRadius="270"/>
        </Grid>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto"
                      ZoomMode="Disabled">
            <Grid x:Name="MainShellGrid"
                  MaxWidth="1380"
                  Margin="28"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch"
                  ColumnSpacing="24"
                  RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition x:Name="MainShellBottomRow" Height="0"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="260"/>
                    <ColumnDefinition x:Name="ContentColumn" Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarPanel"
                        Grid.Column="0"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Padding="22"
                        Background="{StaticResource HeroPanelBrush}"
                        BorderBrush="{StaticResource PanelStrongBrush}"
                        BorderThickness="1"
                        CornerRadius="30">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Control"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentStrongBrush}"/>
                            <TextBlock Text="Workspace"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <Border Background="{StaticResource PanelSurfaceBrush}"
                                BorderBrush="{StaticResource PanelStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Navigation"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="新增功能與資料監測都從這裡進入"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,26,0,0"
                                Spacing="10"
                                VerticalAlignment="Top">
                        <Button Click="OnSubscriptionsNavClick"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="SubscriptionNavItem"
                                    Background="{StaticResource PanelSurfaceBrush}"
                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource AccentPanelBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="S"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="訂閱管理"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="目前頁面"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnOilMonitoringNavClick"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="OilMonitoringNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource AccentBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="O"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="原油監測"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="OQD Daily Marker Price"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="BatteryStatus"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="BatteryStatusNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource PanelMutedBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="電"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="電池選單"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="充電狀態與估算"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="UsDebt"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="UsDebtNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource PanelMutedBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="US"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="US Debt"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="美國國債資料"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="FengTools"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="FengToolsNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource PanelMutedBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="價"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="鋒兄工具"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="比價工具入口"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="BankStats"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="BankStatsNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource PanelMutedBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="銀"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="銀行統計"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="帳戶與存款彙整"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="FoodManagement"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="FoodManagementNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource PanelMutedBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="食"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="食物管理"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="品項、價格與保存"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="FengNotes"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="FengNotesNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource PanelMutedBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="記"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="常用筆記"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="文章與連結"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="LotteryReason"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="LotteryReasonNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource PanelMutedBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="38"
                                                   Foreground="{StaticResource AccentStrongBrush}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="最瞎結婚理由"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="台彩組合比對"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>

                        <Button Click="OnReferenceFeatureNavClick"
                                Tag="FengCommon"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Border x:Name="FengCommonNavItem"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource AccentSoftBrush}"
                                    BorderThickness="0"
                                    CornerRadius="18"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34"
                                            Height="34"
                                            Background="{StaticResource TextPrimaryBrush}"
                                            CornerRadius="17">
                                        <TextBlock Text="常"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="常用資料"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="帳號與共用資訊"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="14"
                            Background="{StaticResource PanelSurfaceBrush}"
                            BorderBrush="{StaticResource PanelStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <StackPanel Spacing="4">
                            <TextBlock Text="System"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="Tech Surface"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
                </Border>

                <Grid x:Name="ContentHostGrid"
                      Grid.Column="1"
                      Grid.Row="0"
                      Grid.RowSpan="2">
                    <Border x:Name="SubscriptionsSection"
                            Background="Transparent">
                        <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="28"
                                Margin="0,0,0,18"
                                Background="{StaticResource HeroPanelBrush}"
                                BorderBrush="{StaticResource PanelStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="30">
                            <Grid x:Name="SubscriptionsHeroGrid"
                                  ColumnSpacing="28"
                                  RowSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition x:Name="SubscriptionsHeroBottomRow" Height="0"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="SubscriptionsHeroActionsColumn" Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="18">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Subscriptions"
                                                   FontSize="38"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <Border Background="{StaticResource PanelSurfaceBrush}"
                                                BorderBrush="{StaticResource PanelStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                Padding="14,8"
                                                HorizontalAlignment="Left">
                                            <TextBlock x:Name="SubscriptionCountText"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </StackPanel>

                                    <Grid x:Name="SubscriptionsMetaGrid"
                                          ColumnSpacing="28"
                                          RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition x:Name="SubscriptionsMetaRow2" Height="0"/>
                                            <RowDefinition x:Name="SubscriptionsMetaRow3" Height="0"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition x:Name="SubscriptionsMetaColumn2" Width="Auto"/>
                                            <ColumnDefinition x:Name="SubscriptionsMetaColumn3" Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Status" Style="{StaticResource HeaderLabelStyle}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="10" Height="10" Fill="{StaticResource HighlightBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="Live" Style="{StaticResource HeaderValueStyle}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel x:Name="SubscriptionsMetaLayoutPanel"
                                                    Grid.Column="1"
                                                    Spacing="4">
                                            <TextBlock Text="Layout" Style="{StaticResource HeaderLabelStyle}"/>
                                            <TextBlock Text="Modern Grid" Style="{StaticResource HeaderValueStyle}"/>
                                        </StackPanel>

                                        <StackPanel x:Name="SubscriptionsMetaThemePanel"
                                                    Grid.Column="2"
                                                    Spacing="4">
                                            <TextBlock Text="Theme" Style="{StaticResource HeaderLabelStyle}"/>
                                            <TextBlock Text="Tech Surface" Style="{StaticResource HeaderValueStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <Border x:Name="SubscriptionsActionsCard"
                                        Grid.Column="1"
                                        Padding="22"
                                        Background="{StaticResource PanelSurfaceBrush}"
                                        BorderBrush="{StaticResource PanelStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="24">
                                    <StackPanel Spacing="14">
                                        <Button Content="測試通知"
                                                Click="TestNotification_Click"
                                                Style="{StaticResource PrimaryActionButtonStyle}"/>
                                        <ToggleSwitch x:Name="StartupSwitch"
                                                      Header="開機啟動"
                                                      OffContent="關閉"
                                                      OnContent="開啟"
                                                      Toggled="StartupSwitch_Toggled"
                                                      Style="{StaticResource GlassToggleStyle}"/>
                                        <Button Content="按日期排序"
                                                x:Name="SortByNameButton"
                                                Click="SortByNameButton_Click"
                                                Style="{StaticResource ActionButtonStyle}"/>
                                        <Button Content="Refresh"
                                                Click="RefreshButton_Click"
                                                Style="{StaticResource ActionButtonStyle}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="NotificationPanel"
                                Grid.Row="1"
                                Margin="0,0,0,18"
                                Padding="20,16"
                                Background="{StaticResource NotificationBackgroundBrush}"
                                BorderBrush="{StaticResource NotificationBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24"
                                Visibility="Collapsed">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="44"
                                        Height="44"
                                        Background="#FFF8E9"
                                        BorderBrush="{StaticResource NotificationBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="22"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="!"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource NotificationForegroundBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="通知"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource NotificationForegroundBrush}"/>
                                    <ItemsControl x:Name="NotificationList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <TextBlock Text="{x:Bind}"
                                                           Foreground="{StaticResource NotificationForegroundBrush}"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="✕"
                                        Click="DismissNotification_Click"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource NotificationForegroundBrush}"
                                        FontSize="18"
                                        Padding="8,2"
                                        VerticalAlignment="Top"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="24"
                                Background="{StaticResource PanelSurfaceBrush}"
                                BorderBrush="{StaticResource PanelStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="30">
                            <Grid>
                                <ListView ItemsSource="{x:Bind Subscriptions, Mode=OneWay}"
                                          SelectionMode="None"
                                          Style="{StaticResource SubscriptionListStyle}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,14"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:Subscription">
                                            <Border Background="{StaticResource PanelMutedBrush}"
                                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="24"
                                                    Padding="22,20">
                                                <Grid ColumnSpacing="18">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Background="{StaticResource AccentBrush}"
                                                            CornerRadius="999"
                                                            Margin="0,2,0,2"/>

                                                    <StackPanel Grid.Column="1" Spacing="10">
                                                        <TextBlock Text="{x:Bind Name}"
                                                                   FontSize="22"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextWrapping="Wrap"/>

                                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                                            <Border Background="{StaticResource PanelSurfaceBrush}"
                                                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="999"
                                                                    Padding="12,6">
                                                                <TextBlock Text="{x:Bind Site}"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </Border>
                                                            <Border Background="{StaticResource PanelSurfaceBrush}"
                                                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="999"
                                                                    Padding="12,6">
                                                                <TextBlock Text="{x:Bind Account}"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Spacing="6">
                                                            <TextBlock Text="{x:Bind NextDate}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{x:Bind Note}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       FontStyle="Italic"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                Width="170"
                                                                VerticalAlignment="Center"
                                                                Spacing="8">
                                                        <Border Background="{StaticResource AccentPanelBrush}"
                                                                BorderBrush="{StaticResource AccentSoftBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="20"
                                                                Padding="18,16">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{x:Bind Price}"
                                                                           FontSize="30"
                                                                           FontWeight="Bold"
                                                                           Foreground="{StaticResource AccentStrongBrush}"
                                                                           HorizontalAlignment="Right"/>
                                                                <TextBlock Text="per month"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           HorizontalAlignment="Right"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                              Width="42"
                                              Height="42"
                                              Foreground="{StaticResource AccentBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="OilMonitoringSection"
                            Visibility="Collapsed">
                        <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="28"
                                Margin="0,0,0,18"
                                Background="{StaticResource HeroPanelBrush}"
                                BorderBrush="{StaticResource PanelStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="30">
                            <Grid x:Name="OilHeroGrid"
                                  ColumnSpacing="28"
                                  RowSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition x:Name="OilHeroBottomRow" Height="0"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="OilHeroActionsColumn" Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="12">
                                    <TextBlock Text="原油監測"
                                               FontSize="38"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="OilMonitoringStatusText"
                                               Text="每日 13:00 自動抓取"
                                               FontSize="14"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="OilSourceText"
                                               Text="來源: gulfmerc.com 首頁 OQD Daily Marker Price"
                                               FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <StackPanel x:Name="OilHeroActionsPanel"
                                            Grid.Column="1"
                                            Spacing="12">
                                    <Button Content="立即抓取"
                                            Click="FetchOilMonitoringButton_Click"
                                            Style="{StaticResource PrimaryActionButtonStyle}"/>
                                    <Button Content="重新整理圖表"
                                            Click="RefreshOilMonitoringButton_Click"
                                            Style="{StaticResource ActionButtonStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid x:Name="OilBodyGrid"
                              Grid.Row="1"
                              ColumnSpacing="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="OilBodyBottomRow" Height="0"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="OilChartColumn" Width="2*"/>
                                <ColumnDefinition x:Name="OilSummaryColumn" Width="1.1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="24"
                                    Background="{StaticResource PanelSurfaceBrush}"
                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="30">
                                <StackPanel Spacing="18">
                                    <Grid x:Name="OilMetricsGrid"
                                          ColumnSpacing="14"
                                          RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition x:Name="OilMetricsRow2" Height="0"/>
                                            <RowDefinition x:Name="OilMetricsRow3" Height="0"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition x:Name="OilMetricsColumn2" Width="*"/>
                                            <ColumnDefinition x:Name="OilMetricsColumn3" Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Background="{StaticResource PanelMutedBrush}"
                                                BorderBrush="{StaticResource PanelStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="22"
                                                Padding="16">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="最新價格"
                                                           Style="{StaticResource HeaderLabelStyle}"/>
                                                <TextBlock x:Name="OilLatestPriceText"
                                                           Text="--"
                                                           FontSize="28"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource AccentStrongBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="OilLastUpdatedCard"
                                                Grid.Column="1"
                                                Background="{StaticResource PanelMutedBrush}"
                                                BorderBrush="{StaticResource PanelStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="22"
                                                Padding="16">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="最後更新"
                                                           Style="{StaticResource HeaderLabelStyle}"/>
                                                <TextBlock x:Name="OilLastUpdatedText"
                                                           Text="尚未抓取"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="OilHistoryCountCard"
                                                Grid.Column="2"
                                                Background="{StaticResource PanelMutedBrush}"
                                                BorderBrush="{StaticResource PanelStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="22"
                                                Padding="16">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="歷史筆數"
                                                           Style="{StaticResource HeaderLabelStyle}"/>
                                                <TextBlock x:Name="OilHistoryCountText"
                                                           Text="0 天"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Background="{StaticResource PanelMutedBrush}"
                                            BorderBrush="{StaticResource PanelStrongBrush}"
                                            BorderThickness="1"
                                            CornerRadius="24"
                                            Padding="16">
                                        <Grid>
                                            <Canvas x:Name="OilChartCanvas"
                                                    Height="300"/>
                                            <TextBlock x:Name="ChartEmptyState"
                                                       Text="目前還沒有原油監測資料，先按一次立即抓取。"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="OilSummaryCard"
                                    Grid.Column="1"
                                    Padding="24"
                                    Background="{StaticResource PanelSurfaceBrush}"
                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="30">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="監測摘要"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Border Background="{StaticResource PanelMutedBrush}"
                                            BorderBrush="{StaticResource PanelStrongBrush}"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            Padding="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="資料來源"
                                                       Style="{StaticResource HeaderLabelStyle}"/>
                                            <TextBlock Text="Gulf Mercantile Exchange"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="https://www.gulfmerc.com/"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource PanelMutedBrush}"
                                            BorderBrush="{StaticResource PanelStrongBrush}"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            Padding="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="抓取規則"
                                                       Style="{StaticResource HeaderLabelStyle}"/>
                                            <TextBlock Text="每日 13:00 自動抓取 OQD Daily Marker Price"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="啟動常駐後會持續累積本機歷史資料，供圖表使用。"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="ReferenceFeatureSection"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="28"
                                    Margin="0,0,0,18"
                                    Background="{StaticResource HeroPanelBrush}"
                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="30">
                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="ReferenceFeatureEyebrowText"
                                               Text="Reference"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentStrongBrush}"/>
                                    <TextBlock x:Name="ReferenceFeatureTitleText"
                                               Text="功能入口"
                                               FontSize="38"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="ReferenceFeatureDescriptionText"
                                               Text="此功能已依參考 Android 專案加入選單，後續可在 Uno 版接上完整資料與畫面。"
                                               FontSize="15"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Padding="24"
                                    Background="{StaticResource PanelSurfaceBrush}"
                                    BorderBrush="{StaticResource PanelStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="30">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="已加入主選單"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="ReferenceFeatureStatusText"
                                               Text="目前是功能入口頁，保留參考專案的名稱與用途說明。"
                                               FontSize="14"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <Grid ColumnSpacing="14" RowSpacing="14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Background="{StaticResource PanelMutedBrush}"
                                                BorderBrush="{StaticResource PanelStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="20"
                                                Padding="16">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="來源"
                                                           Style="{StaticResource HeaderLabelStyle}"/>
                                                <TextBlock Text="appwriteandroidtrae"
                                                           Style="{StaticResource HeaderValueStyle}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Background="{StaticResource PanelMutedBrush}"
                                                BorderBrush="{StaticResource PanelStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="20"
                                                Padding="16">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="狀態"
                                                           Style="{StaticResource HeaderLabelStyle}"/>
                                                <TextBlock Text="選單入口已建立"
                                                           Style="{StaticResource HeaderValueStyle}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Background="{StaticResource PanelMutedBrush}"
                                                BorderBrush="{StaticResource PanelStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="20"
                                                Padding="16">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="下一步"
                                                           Style="{StaticResource HeaderLabelStyle}"/>
                                                <TextBlock Text="若需要完整功能，可逐一移植 Android 專案中的資料服務、畫面欄位與排程邏輯。"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
